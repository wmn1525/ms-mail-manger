APP_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
PUBLIC_API_KEY=replace-with-a-public-api-key
JWT_EXPIRE_MINUTES=720

DATABASE_URL=sqlite:////app/backend/data/app.db
FRONTEND_DIST_DIR=/app/frontend/dist

CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000","http://localhost:5173","http://127.0.0.1:5173"]

IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_FOLDER=INBOX
MICROSOFT_SCOPE=https://outlook.office.com/IMAP.AccessAsUser.All offline_access
